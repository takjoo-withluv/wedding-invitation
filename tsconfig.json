{
  "compilerOptions": {
    "target": "esnext",         // 👈 "es5"에서 "esnext" (또는 "es2020")로 변경
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "bundler", // 👈 "node"에서 "bundler"로 변경
    "allowImportingTsExtensions": true, // 👈 bundler 사용 시 추가 권장
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite-plugin-svgr/client"]
  },
  "include": [
    "src"
  ]
}